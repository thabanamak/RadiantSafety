# --- CRITICAL SECRETS (STRICT - DO NOT CHANGE) ---
.env
.env.local
.env*.local
*.pem
*.key
# Supabase CLI project dir (repo root only — not `src/lib/supabase/` app code)
/supabase/
.supabase/
# Keep these out so you don't leak your Mapbox/Supabase keys!

# --- PYTHON SETTINGS ---
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
# Friends should create their own venv using the commands I gave you.

# --- NODE / NEXT.JS ---
node_modules/
tsconfig.tsbuildinfo
.next/
out/
npm-debug.log*
.vercel/

# --- PROJECT FILES (RELAXED) ---
# We are NOT ignoring .vscode or .idea anymore so friends get your settings
# We are NOT ignoring build/ or dist/ if you have static assets there

# --- DATA & LOGS ---
*.log
.DS_Store
# Ensure your CSV crime data is NOT ignored if they need it to run the script
# If you want them to have the crime file, make sure it's not named 'data.log' or similar

# --- CURSOR ---
.cursorindexingignore
# We removed .cursorignore so everyone gets the same AI context